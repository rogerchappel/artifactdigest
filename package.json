{
  "name": "artifactdigest",
  "version": "0.1.0",
  "description": "Deterministic build artifact digest tracking for CI/CD pipelines.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "test": "node --test",
    "package:smoke": "node scripts/package-smoke.mjs",
    "release:check": "npm test && npm run package:smoke",
    "smoke": "node --test && echo smoke OK",
    "build": "echo build OK"
  },
  "keywords": [
    "agent",
    "artifact",
    "digest",
    "evidence",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/artifactdigest.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/artifactdigest/issues"
  },
  "homepage": "https://github.com/rogerchappel/artifactdigest#readme",
  "bin": {
    "artifactdigest": "src/cli.js"
  },
  "engines": {
    "node": ">=20"
  }
}
